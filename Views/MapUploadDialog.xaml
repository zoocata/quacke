<Window x:Class="QuakeServerManager.Views.MapUploadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upload Custom Maps"
        Height="450"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1E1E1E">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Upload Custom Maps"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>
            <TextBlock Text="Select .bsp map files to add to your server instances."
                       FontSize="12"
                       Opacity="0.7"/>
        </StackPanel>

        <!-- Map List -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                <Button Content="Add Maps..." Click="AddMaps_Click" Width="120"/>
                <Button Content="Remove Selected" Click="RemoveSelected_Click" Width="120"/>
                <Button Content="Clear All" Click="ClearAll_Click" Width="120"/>
            </StackPanel>

            <!-- Selected Maps List -->
            <Border Grid.Row="1"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    Background="#252526">
                <ListBox x:Name="MapListBox"
                         SelectionMode="Extended"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁 " FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding FileName}" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding SizeFormatted}" Opacity="0.7"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <!-- Target Selection -->
        <Border Grid.Row="2"
                BorderBrush="#3E3E42"
                BorderThickness="1"
                Background="#2D2D30"
                Padding="10"
                Margin="0,10,0,10">
            <StackPanel>
                <TextBlock Text="Apply to:" FontWeight="Bold" Margin="0,0,0,5"/>
                <RadioButton x:Name="AllInstancesRadio"
                             Content="All server instances"
                             IsChecked="True"
                             Foreground="White"
                             Margin="0,5"/>
                <RadioButton x:Name="SelectedInstancesRadio"
                             Content="Only selected instances"
                             Foreground="White"
                             Margin="0,5"/>
            </StackPanel>
        </Border>

        <!-- Dialog Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Upload"
                    Click="Upload_Click"
                    Width="100"
                    IsDefault="True"
                    Background="#0E639C"
                    BorderBrush="#007ACC"/>
            <Button Content="Cancel"
                    Click="Cancel_Click"
                    Width="100"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
